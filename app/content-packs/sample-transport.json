  "sentences": [
    {
      "id": "st-1",
      "text": "De trein naar Amsterdam vertrekt om negen uur.",
      "translation": "The train to Amsterdam departs at nine o'clock.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-2",
      "text": "Ik wil graag een kaartje naar Utrecht.",
      "translation": "I would like a ticket to Utrecht.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-3",
      "text": "Op welk perron vertrekt de trein?",
      "translation": "From which platform does the train depart?",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-4",
      "text": "Er is helaas vertraging op dit traject.",
      "translation": "There is unfortunately a delay on this route.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-5",
      "text": "De bus stopt bij elke halte.",
      "translation": "The bus stops at every stop.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-6",
      "text": "Ik ga met de fiets naar het station.",
      "translation": "I go to the station by bicycle.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-7",
      "text": "De reis duurt twee uur.",
      "translation": "The journey takes two hours.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-8",
      "text": "In welke richting moet ik lopen?",
      "translation": "In which direction should I walk?",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-9",
      "text": "De trein staat op spoor vijf.",
      "translation": "The train is on track five.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-10",
      "text": "Elke reiziger moet een kaartje hebben.",
      "translation": "Every traveler must have a ticket.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-11",
      "text": "De trein gaat om acht uur vertrekken.",
      "translation": "The train will depart at eight o'clock.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-12",
      "text": "Wanneer gaat de bus aankomen?",
      "translation": "When will the bus arrive?",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-13",
      "text": "U moet in Leiden overstappen.",
      "translation": "You have to transfer in Leiden.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-14",
      "text": "Wij gaan nu instappen in de trein.",
      "translation": "We are going to board the train now.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-15",
      "text": "Bij de volgende halte moet je uitstappen.",
      "translation": "You have to get off at the next stop.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    },
    {
      "id": "st-16",
      "text": "De conductor controleert de kaartjes.",
      "translation": "The conductor checks the tickets.",
      "lessonId": "les-train",
      "classGroupId": "cg-train-vocab"
    }
  ],
