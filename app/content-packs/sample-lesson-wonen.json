  ],
  "dialogTurns": [
    {
      "id": "dwt-1",
      "dialogId": "dw-1",
      "speaker": "Makelaar",
      "text": "Goedemiddag, waarnaar bent u op zoek?",
      "translation": "Good afternoon, what are you looking for?",
      "orderIndex": 0
    },
    {
      "id": "dwt-2",
      "dialogId": "dw-1",
      "speaker": "Klant",
      "text": "Wij zoeken een huis met drie kamers en een tuin.",
      "translation": "We are looking for a house with three rooms and a garden.",
      "orderIndex": 1
    },
    {
      "id": "dwt-3",
      "dialogId": "dw-1",
      "speaker": "Makelaar",
      "text": "Hoeveel huur wilt u maximaal betalen?",
      "translation": "How much rent do you want to pay at most?",
