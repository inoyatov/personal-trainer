  "sentences": [
    {
      "id": "sw-1",
      "text": "Wij zoeken een nieuw huis met een tuin.",
      "translation": "We are looking for a new house with a garden.",
      "lessonId": "les-wonen",
      "classGroupId": "cg-wonen-vocab"
    },
    {
      "id": "sw-2",
      "text": "De huur is vijfhonderd euro per maand.",
      "translation": "The rent is five hundred euros per month.",
      "lessonId": "les-wonen",
      "classGroupId": "cg-wonen-vocab"
    },
    {
      "id": "sw-3",
      "text": "Wij gaan volgende maand verhuizen.",
      "translation": "We are going to move next month.",
      "lessonId": "les-wonen",
      "classGroupId": "cg-wonen-vocab"
    },
    {
      "id": "sw-4",
      "text": "Mag ik de sleutel van de kamer?",
      "translation": "May I have the key to the room?",
      "lessonId": "les-wonen",
      "classGroupId": "cg-wonen-vocab"
    }
  ],
  "dialogs": [
    {
      "id": "dw-1",
