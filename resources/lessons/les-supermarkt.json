  "sentences": [
    {
      "id": "s-supermarkt-1",
      "text": "Ik ga naar de supermarkt.",
      "translation": "I go to the supermarket.",
      "lessonId": "les-supermarkt",
      "classGroupId": "cg-supermarkt-vocab"
    },
    {
      "id": "s-supermarkt-2",
      "text": "Ik doe elke dag een boodschap.",
      "translation": "I do groceries every day.",
      "lessonId": "les-supermarkt",
      "classGroupId": "cg-supermarkt-vocab"
    },
    {
      "id": "s-supermarkt-3",
      "text": "Ik neem een kar in de supermarkt.",
      "translation": "I take a shopping cart in the supermarket.",
      "lessonId": "les-supermarkt",
      "classGroupId": "cg-supermarkt-vocab"
    },
    {
      "id": "s-supermarkt-4",
      "text": "Dit product is goedkoop.",
      "translation": "This product is cheap.",
      "lessonId": "les-supermarkt",
      "classGroupId": "cg-supermarkt-vocab"
    },
    {
      "id": "s-supermarkt-5",
      "text": "De prijs van dit product is laag.",
      "translation": "The price of this product is low.",
      "lessonId": "les-supermarkt",
      "classGroupId": "cg-supermarkt-vocab"
    },
    {
      "id": "s-supermarkt-6",
      "text": "Ik wil brood kopen.",
      "translation": "I want to buy bread.",
      "lessonId": "les-supermarkt",
      "classGroupId": "cg-supermarkt-vocab"
    },
    {
      "id": "s-supermarkt-7",
      "text": "Ik ga bij de kassa betalen.",
      "translation": "I am going to pay at the cashier.",
      "lessonId": "les-supermarkt",
      "classGroupId": "cg-supermarkt-vocab"
    }
  ],
  "dialogs": [
    {
      "id": "d-supermarkt",
      "lessonId": "les-supermarkt",
      "title": "In de supermarkt",
      "scenario": "A customer buys products and pays at the supermarket",
      "classGroupId": "cg-supermarkt-dialog"
    }
  ],
  "dialogTurns": [
    {
      "id": "dt-supermarkt-1",
      "dialogId": "d-supermarkt",
      "speaker": "Medewerker",
      "text": "Goedemiddag, kan ik u helpen?",
      "translation": "Good afternoon, can I help you?",
      "orderIndex": 0
    },
    {
      "id": "dt-supermarkt-2",
      "dialogId": "d-supermarkt",
      "speaker": "Klant",
      "text": "Ja, waar kan ik dit product vinden?",
      "translation": "Yes, where can I find this product?",
      "orderIndex": 1
    },
    {
      "id": "dt-supermarkt-3",
      "dialogId": "d-supermarkt",
      "speaker": "Medewerker",
      "text": "Het product ligt daar bij de groenten.",
      "translation": "The product is there near the vegetables.",
      "orderIndex": 2
    },
    {
      "id": "dt-supermarkt-4",
      "dialogId": "d-supermarkt",
      "speaker": "Klant",
      "text": "Dank u, ik ga het kopen.",
      "translation": "Thank you, I am going to buy it.",
      "orderIndex": 3
    },
    {
      "id": "dt-supermarkt-5",
      "dialogId": "d-supermarkt",
      "speaker": "Medewerker",
      "text": "U kunt bij de kassa betalen.",
      "translation": "You can pay at the cashier.",
      "orderIndex": 4
    }
  ],
  "grammarPatterns": [
    {
      "id": "gp-supermarkt-1",
      "name": "Modal verb: willen",
      "description": "Using 'willen' to express desire",
      "explanationMarkdown": "**Willen** is used to say what you want.\n\n- Ik wil brood kopen.\n- Ik wil een product kopen.",
      "examples": "[\"Ik wil brood kopen.\", \"Ik wil een product kopen.\"]",
      "lessonId": "les-supermarkt"
    }
  ],
